generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id                  String           @id @default(cuid())
  name                String
  address             String
  email               String           @unique
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  phone               String
  plan                BusinessPlan     @default(ADVANCED)
  businessHours       Json             @default("{}")
  specialDays         Json?
  defaultSlotInterval Int              @default(30)
  deletedAt           DateTime?
  appointments        Appointment[]
  blockedTimes        BlockedTime[]
  clients             BusinessClient[]
  services            Service[]
  users               User[]
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  password            String
  role                UserRole             @default(EMPLOYEE)
  businessId          String
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  phone               String?
  deletedAt           DateTime?
  appointments        Appointment[]
  appointmentServices AppointmentService[]
  blockedTimes        BlockedTime[]
  businesses          Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  schedules           UserSchedule[]
  services            UserService[]

  @@unique([email, deletedAt])
}

model UserSchedule {
  id        String    @id @default(cuid())
  userId    String
  dayOfWeek WeekDay
  startTime String
  endTime   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
}

model BlockedTime {
  id         String   @id @default(cuid())
  date       DateTime
  start      String
  end        String
  businessId String
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId, date])
}

model BusinessClient {
  id           String        @id @default(cuid())
  businessId   String
  clientId     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  appointments Appointment[]
  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  notes        Note[]

  @@unique([businessId, clientId])
}

model Client {
  id          String           @id @default(cuid())
  name        String
  email       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  phone       String           @unique
  isConfirmed Boolean          @default(false)
  firebaseUid String? @unique
  businesses  BusinessClient[]
}

model Appointment {
  id               String               @id @default(cuid())
  date             DateTime
  status           AppointmentStatus    @default(SCHEDULED)
  userId           String?
  businessId       String
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  businessClientId String
  durationMin      Int
  endTime          String
  startTime        String
  endTimeMinutes   Int
  startTimeMinutes Int
  amount           Int                  @default(0)
  deletedAt        DateTime?
  businessClient   BusinessClient       @relation(fields: [businessClientId], references: [id], onDelete: Cascade)
  business         Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user             User?                @relation(fields: [userId], references: [id])
  services         AppointmentService[]

  @@index([businessId, date, status])
}

model Service {
  id              String               @id @default(cuid())
  name            String
  durationMin     Int
  price           Float
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  description     String?
  imageUrl        String?
  businessId      String
  category        String?
  cleaningTimeMin Int                  @default(0)
  isActive        Boolean              @default(true)
  appointments    AppointmentService[]
  business        Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  users           UserService[]

  @@index([businessId])
}

model AppointmentService {
  id            String      @id @default(cuid())
  appointmentId String
  serviceId     String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  userId        String?
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service       Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@unique([appointmentId, serviceId])
  @@index([appointmentId])
  @@index([userId])
}

model UserService {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
}

model Note {
  id               String         @id @default(cuid())
  content          String
  createdAt        DateTime       @default(now())
  businessClientId String
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  client           BusinessClient @relation(fields: [businessClientId], references: [id], onDelete: Cascade)
}

enum WeekDay {
  sunday
  monday
  tuesday
  wednesday
  thursday
  friday
  saturday
}

enum BusinessPlan {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum AppointmentStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  CONFIRMED
}
